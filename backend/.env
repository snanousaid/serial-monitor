DATABASE_URL="file:./dev.db"
JWT_SECRET="super_secret_key_change_me_in_production"
JWT_EXPIRES_IN="8h"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"
SERIAL_PORT="COM3"
SERIAL_BAUD_RATE=9600

MQTT_BROKER="mqtt://localhost:1883"
MQTT_TOPIC="devices/data"
MQTT_CLIENT_ID="serial-monitor-backend"
MQTT_USERNAME=""
MQTT_PASSWORD=""


PRISMA_QUERY_ENGINE_BINARY=/home/nextronic/serial-monitor/PrismaEngine/query-engine
PRISMA_INTROSPECTION_ENGINE_BINARY=/home/nextronic/serial-monitor/PrismaEngine/introspection-engine
PRISMA_FMT_BINARY=/home/nextronic/serial-monitor/PrismaEngine/prisma-fmt
PRISMA_QUERY_ENGINE_LIBRARY=/home/nextronic/serial-monitor/PrismaEngine/libquery_engine_napi.so.node
PRISMA_SCHEMA_ENGINE_BINARY=/home/nextronic/serial-monitor/PrismaEngine/schema-engine
PRISMA_MIGRATION_ENGINE_BINARY=/home/nextronic/serial-monitor/PrismaEngine/migration-engine
PRISMA_CLI_BINARY_TARGETS=linux-arm-openssl-1.0.x
PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1
PRISMA_SKIP_POSTINSTALL_GENERATE=1