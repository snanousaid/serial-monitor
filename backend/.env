# ═══════════════════════════════════════════════════
# ENVIRONNEMENT PROD — ARM32 (nextronic)
# Usage : cp .env.arm32 .env  (sur le device ARM32)
# ═══════════════════════════════════════════════════

DATABASE_PATH="dev.db"

JWT_SECRET="CHANGE_ME_PRODUCTION_SECRET_KEY_32chars"
JWT_EXPIRES_IN="8h"

ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

# Port série sur Linux
SERIAL_PORT="/dev/ttyUSB0"
SERIAL_BAUD_RATE=9600

# Broker MQTT
MQTT_BROKER="mqtt://localhost:1883"
MQTT_TOPIC="devices/data"
MQTT_CLIENT_ID="serial-monitor-backend-arm32"
MQTT_USERNAME=""
MQTT_PASSWORD=""
