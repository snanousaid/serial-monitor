{
  "name": "serial-monitor-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",

    "env:windows": "copy .env.windows .env",
    "env:arm32":   "cp .env.arm32 .env",

    "prisma:generate":   "prisma generate",
    "prisma:push":       "prisma db push --skip-generate",
    "prisma:migrate":    "prisma migrate dev --name init",

    "install:arm32":     "PRISMA_SKIP_POSTINSTALL_GENERATE=1 npm install --ignore-scripts",
    "start:arm32":       "node dist/main"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/websockets": "^10.3.0",
    "@prisma/client": "^5.10.0",
    "@nestjs/config": "^3.2.0",
    "bcryptjs": "^2.4.3",
    "mqtt": "^5.5.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "serialport": "^12.0.0",
    "socket.io": "^4.7.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^5.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
